if(images.desktop_image){$node.css('background-image','url('+images.desktop_image+')');}});}
var swiperInstance=null,isTtl=document.documentElement.dir.toLowerCase()==='rtl',autoplaySpeed=Number($element.data('autoplay-speed'))||0,hasAutoplay=true,progressStartTime=0,remainingTime=autoplaySpeed,resumeOnce=false,isPausedManually=false,isHovering=false;function getCurrentProgressBar(){return $element.find('.slick-current .hp-progress');}
function resetProgress($bar){if(!$bar||!$bar.length){return;}
$bar.css({transition:'none',width:'0%'});$bar[0].offsetHeight;}
function getProgressPercent($bar){if(!$bar||!$bar.length){return 0;}
var $container=$bar.closest('.hp-progress-container');var containerWidth=$container.length?$container.width():0;var currentWidth=$bar.width();return containerWidth?(currentWidth / containerWidth)*100:0;}
function freezeProgress($bar){if(!$bar||!$bar.length){return;}
var percent=getProgressPercent($bar);$bar.css({transition:'none',width:percent+'%'});}
function startProgress(duration){if(!hasAutoplay||autoplaySpeed<=0){return;}
var $bar=getCurrentProgressBar();if(!$bar.length){return;}
var transitionDuration=typeof duration==='number'?duration:autoplaySpeed;resetProgress($bar);progressStartTime=Date.now();remainingTime=transitionDuration;$bar.css({transition:'width '+transitionDuration+'ms linear',width:'100%'});}
function resumeProgress(){if(!hasAutoplay||autoplaySpeed<=0){return;}
var $bar=getCurrentProgressBar();if(!$bar.length){return;}
if(remainingTime<=0){$(element).slick('slickNext');return;}
resumeOnce=true;$(element).slick('slickSetOption','autoplaySpeed',remainingTime,true);$(element).slick('slickPlay');progressStartTime=Date.now();$bar.css({transition:'width '+remainingTime+'ms linear',width:'100%'});}
if($element.hasClass('slick-initialized')){$element.slick('unslick');}
$element.off('.hpProgress');$element.on('init.hpProgress',function(){startProgress();});$element.on('beforeChange.hpProgress',function(){resetProgress(getCurrentProgressBar());});$element.on('afterChange.hpProgress',function(){if(resumeOnce){$(element).slick('slickSetOption','autoplaySpeed',autoplaySpeed,true);resumeOnce=false;}
if(isHovering||isPausedManually){remainingTime=autoplaySpeed;progressStartTime=0;resetProgress(getCurrentProgressBar());return;}
startProgress();});$element.slick({autoplay:true,autoplaySpeed:$element.data('autoplay-speed')||3000,fade:$element.data('fade'),infinite:$element.data('infinite-loop'),arrows:$element.data('show-arrows'),prevArrow:'<button class="slick-prev" aria-label="Previous" type="button">'+leftArrowIcon+'</button>',nextArrow:'<button class="slick-next" aria-label="Next" type="button">'+rightArrowIcon+'</button>',dots:true,waitForAnimate:false,swipe:false,customerSlick:true,pauseOnFocus:false,rtl:isTtl});applyResponsiveBackgrounds();if(typeof mobileMediaQuery.addEventListener==='function'){mobileMediaQuery.addEventListener('change',applyResponsiveBackgrounds);}else if(typeof mobileMediaQuery.addListener==='function'){mobileMediaQuery.addListener(applyResponsiveBackgrounds);}
if(isTtl){$element.on('click','.hp-carousel-right-arrow-box',function(){remainingTime=autoplaySpeed;progressStartTime=0;resumeOnce=false;$(element).slick('slickPrev');$(element).slick('slickSetOption','autoplaySpeed',autoplaySpeed,true);$(element).slick('slickSetOption','autoplay',true,true);$(element).slick('slickPlay');$(this).siblings('.pause-button').show();});$element.on('click','.hp-carousel-left-arrow-box',function(){remainingTime=autoplaySpeed;progressStartTime=0;resumeOnce=false;$(element).slick('slickNext');$(element).slick('slickSetOption','autoplaySpeed',autoplaySpeed,true);$(element).slick('slickSetOption','autoplay',true,true);$(element).slick('slickPlay');$(this).siblings('.pause-button').show();});}else{$element.on('click','.hp-carousel-left-arrow-box',function(){remainingTime=autoplaySpeed;progressStartTime=0;resumeOnce=false;$(element).slick('slickPrev');$(element).slick('slickSetOption','autoplaySpeed',autoplaySpeed,true);$(element).slick('slickSetOption','autoplay',true,true);$(element).slick('slickPlay');$(this).siblings('.pause-button').show();});$element.on('click','.hp-carousel-right-arrow-box',function(){remainingTime=autoplaySpeed;progressStartTime=0;resumeOnce=false;$(element).slick('slickNext');$(element).slick('slickSetOption','autoplaySpeed',autoplaySpeed,true);$(element).slick('slickSetOption','autoplay',true,true);$(element).slick('slickPlay');$(this).siblings('.pause-button').show();});}
function isInHoverZone(target){var $target=$(target);return $target.closest('.slick-list').length>0||$target.is('button.slick-arrow')||$target.closest('button.slick-arrow').length>0;}
$element.on('mouseenter','.slick-list, button.slick-arrow',function(){isHovering=true;if(!isPausedManually&&hasAutoplay&&autoplaySpeed>0){$element.slick('slickPause');if(progressStartTime){remainingTime=Math.max(0,remainingTime-(Date.now()-progressStartTime));progressStartTime=0;}
freezeProgress(getCurrentProgressBar());$element.find('.pause-button').hide();$element.find('.play-button').show();}});$element.on('mouseleave','.slick-list, button.slick-arrow',function(e){if(isInHoverZone(e.relatedTarget)){return;}
isHovering=false;if(!isPausedManually&&hasAutoplay&&autoplaySpeed>0){resumeProgress();$element.find('.play-button').hide();$element.find('.pause-button').show();}});$element.on('click','.pause-button',function(){isPausedManually=true;$element.slick('slickPause');$(this).hide();$(this).siblings('.play-button').show();if(progressStartTime){remainingTime=Math.max(0,remainingTime-(Date.now()-progressStartTime));}

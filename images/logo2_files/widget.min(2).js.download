define(['jquery','Magento_PageBuilder/js/events','Magento_PageBuilder/js/resource/slick/slick',],function($,events,slick){'use strict';return function(config,element){var $element=$(element);var mobileMediaQuery=window.matchMedia('(max-width: 1023px)');let leftArrowIcon='<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 80 80" height="80" width="80" data-test-hook="@hpstellar/core/icon/ChevronLeft" aria-hidden="true"><g><path d="M50 60a1 1 0 0 0 .72-.31 1 1 0 0 0 0-1.41L31.45 40l19.24-18.28a1 1 0 1 0-1.38-1.44l-20 19a1 1 0 0 0 0 1.44l20 19A1 1 0 0 0 50 60"></path></g></svg>',rightArrowIcon='<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 80 80" height="80" width="80" data-test-hook="@hpstellar/core/icon/ChevronRight" aria-hidden="true"><g><path d="M30 60a1 1 0 0 1-.72-.31 1 1 0 0 1 0-1.41L48.55 40 29.31 21.72a1 1 0 1 1 1.38-1.44l20 19a1 1 0 0 1 0 1.44l-20 19A1 1 0 0 1 30 60"></path></g></svg>';function getBackgroundImages($node){var raw=$node.attr('data-background-images');if(!raw){return null;}
try{return JSON.parse(raw.replace(/\\(.)/g,'$1'))||null;}catch(e){return null;}}
function applyResponsiveBackgrounds(){$element.find('[data-background-images]').each(function(){var $node=$(this);var images=getBackgroundImages($node);if(!images){return;}

define(['jquery','uiComponent','mage/translate','escaper'],function($,Component,$t,escaper){return Component.extend({initialize:function(config){if($(config.lowestPriceClass).length>0){$.ajax({type:'POST',url:config.priceUrl,data:{"param":$(config.lowestPriceClass).data("params")},dataType:'JSON',success:function(result){if(result.status==='success'){$('.'+escaper.escapeHtml(result.cacheKey)).html(escaper.escapeHtml(result.lowest_price,['span']));if(result.lowest_excluded_tax_price!=="0"){$('.'+escaper.escapeHtml(result.excludedTaxCacheKey)).html('<br>'+escaper.escapeHtml(result.lowest_excluded_tax_price,['span']));}}}});}}});});
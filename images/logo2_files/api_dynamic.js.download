",\n  "780K8AA#ABU", "9R181AA#ABU", "AV4K1AA#ABU", "AV4H6AA#ABU", "AW3V0AA#ABU", "AV4C1AA#ABU"\n];\n\n        \n        // Check if the product name includes any of the SKUs\n        const displayOverlay = skus.some(sku => productName.includes(sku));\n        \n        return displayOverlay;\n    } else {\n        console.error("Product name element not found or contains no text.");\n        return false; // Or handle the error as needed\n    }\n});'},13755:{code:"// DYO.Q\nconst getProductSku = () => {\n  if (\n    window.DY &&\n    window.DY.feedProperties &&\n    window.DY.feedProperties.sku\n  ) {\n    return window.DY.feedProperties.sku;\n  }\n  return 'AAAAAA#AA';\n}\ngetProductSku();"},13819:{code:"// DYO.Q\nDYO.Q(DYO.waitForElementAsync(\".product-info-main span.sku\", 1, 20, 100))\n    .then(function () {\n        const skuNode = document.querySelector(\".product-info-main span.sku\");\n        if (skuNode === null) return \"False\";\n\n        const skusApproved = ['B90KQPA','BP0J7PA','BK1U0PA','BT6B4PA','B17S7PA','BP0J9PA','BG6E6PA','C08Q6PA','C08Q7PA','C25MSPA','C2XD2PA','C28DWPA','BT6D0PA','BV0R4PA','BV2W0PA','D30WKPA'];\n\t\tconst sku = skuNode.textContent.trim();\n        return  skusApproved.includes(sku) ? \"True\" : \"False\"; \n    }, function () {\n        return \"False\";\n    });\n"},13907:{code:'const hasSpecificFacets = () => {\n  const pathname = window.location.pathname; \n  const targetFacets = [\n    "business-laptops.html",\n    "business-desktops.html",\n    "business-printers.html",\n    "business-monitors.html",\n    "business-accessories.html",\n    "z-workstations.html",\n    "zbook-laptops.html",\n  ];\n\n  return targetFacets.some(facet => pathname.includes(facet)) ? "True" : "False";\n}\n\nhasSpecificFacets();'},13949:{code:'DYO.Q(DYO.waitForElementAsync(\'.window-banner-container\', 1, 100, 10)).then(function (elements) {\n    const businessPLs = [\n        "BO", "AU", "7T", "DU", "GA", "G7", "M1", "5U", "DG", "AN", "M0", "6U", "TB", "7F"\n    ];\n    \n    return new Promise((resolve, reject) => {\n        DY.ServerUtil.getProductsData([DY.feedProperties.sku], [\'\'], \'view\', true, function(err, res) {\n            if (err) {\n                reject(err);\n                return;\n            }\n            const currentPL = res[DY.feedProperties.sku].productData.product_line;\n            if (currentPL) {\n                resolve(businessPLs.some(businessPL => businessPL === currentPL));\n            } else {\n                resolve(false);\n            }\n        });\n    });\n}).then(function(result) {\n    return result;\n}).catch(function(error) {\n    return false;\n});'},14068:{code:"DYO.Q(DYO.waitForElementAsync('.window-banner-container', 1, 100, 10)).then(function () {\n  return new Promise(function (resolve) {\n    // --- subbrand check ---\n    const subbrandRaw = DY?.feedProperties?.hp_facet_subbrand || [];\n    const subbrands = (Array.isArray(subbrandRaw) ? subbrandRaw : [subbrandRaw])\n      .map(c => c.toLowerCase());\n\n    const hasInclude = subbrands.some(c =>\n      c.includes('inkjet') || c.includes('envy') || c.includes('deskjet') || c.includes('officejet')\n    );\n\n    // --- categories check ---\n    const catsRaw = DY?.feedProperties?.categories || [];\n    const categories = (Array.isArray(catsRaw) ? catsRaw : [catsRaw])\n      .map(c => c.toLowerCase());\n\n    const categoriesHasMobile = categories.some(c => c.includes('mobile'));\n\n    resolve(hasInclude && !categoriesHasMobile);\n  });\n}).then(function (result) {\n  return result; // true / false\n}).catch(function () {\n  return false;\n});\n"},14356:{code:'(async () => {\n  // === Copilot allowlist (PLs) ===\n  const CopilotPLs = new Set([\n    "B17S7PA", "B7TQ7PT", "B7TQ8PT", "B85TQPT", "B85W7PT", "B85TPPT", "B85W6PT", "B8QX7PT", "B8QX8PT", "B8QX0PT", "BH7C0PA", "BH4K3PA", "BK9U3PA", "BK9U4PA", "BK1T2PA", "BK1U0PA", "BQ9B6PT", "BQ9B7PT", "BQ9H6PT", "BP0J7PA", "BE5M7PA", "BK5Y2PA", "BE6Z6PA", "BE7A0PA", "C08Q6PA", "C08Q7PA", "C0YR1PA", "C1NV8PA", "C1NV9PA", "C1NV7PA", "C1NZ7PA", "C1NZ6PA", "C1PG0PA", "C1NZ8PA", "BL1W8PA", "BD2P4PA", "C22HQPT", "C2XD2PA", "C22NGAT", "C22NHAT", "C27TGPT", "C27TFPT", "C1RB2PA", "C7LU0PA", "C8KJ9PA", "C8KK0PA", "C91THPA", "C91TJPA", "C91TKPA", "C20W1PA", "C1QV9PA", "C27T4PT", "C27V6PT", "C27V7PT", "C33M4AT", "C40F2PA", "C88U8PA", "C88TPPA", "BZ6H1PT", "BZ6H7PT", "CG9Y6PA", "C27T5PT", "C27THPT", "C27TDPT", "D30B1PA", "D30B2PA", "D30B3PA", "D30B4PA"\n  ]);\n\n  // Try DY first; then some common fallbacks.\n  const pick = v => (v || \'\').toString().trim().toUpperCase();\n\n  let sku =\n    pick(globalThis?.DY?.feedProperties?.sku) ||\n    pick(globalThis?.digitalData?.product?.[0]?.sku) ||\n    pick(document.querySelector(\'[data-product-id]\')?.getAttribute(\'data-product-id\')) ||\n    \'\';\n\n  if (!sku && Array.isArray(globalThis.dataLayer)) {\n    // try to find any object in dataLayer with a \'sku\' field\n    for (const e of globalThis.dataLayer) {\n      if (e && typeof e === \'object\' && \'sku\' in e) { sku = pick(e.sku); break; }\n    }\n  }\n\n  const isCopilot = CopilotPLs.has(sku);\n  return isCopilot;\n})();\n'},14804:{code:"// DYO.Q\nfunction checkRecommendations() {\n    return new Promise((resolve, reject) => {\n        const interval = setInterval(() => {\n            if (window.DYO && window.DYO.recommendationWidgetData && typeof window.DYO.recommendationWidgetData === 'function') {\n                clearInterval(interval);\n                window.DYO.recommendationWidgetData(294290, {}, (error, data) => {\n                    if (error) {\n                        console.debug('has3Shadow', error);\n                        reject(0);\n                    }\n                    else if (data && data.slots) resolve(data.slots.length);\n                    else reject(0);\n                });\n            }\n        });\n        setTimeout(() => {\n            clearInterval(interval);\n            reject(0);\n        }, 4000);\n    });\n}\ncheckRecommendations().then((response) => {\n        console.debug('has3Shadow', response);\n        return response === 2 ? 'True' : 'False'\n    }, () => 'False').catch(() => 'False');"},14911:{code:"// <meta name=\"store_type\" content=\"epp\">\nDYO.Q.Promise((resolve, reject) => {\n    let counter = 0;\n    const interval = setInterval(() => {\n        counter += 1;\n        const pageTypeMeta = document.querySelector('meta[name=\"store_type\"]');\n        if (pageTypeMeta !== null) {\n            clearInterval(interval);\n            if (pageTypeMeta.content) {\n                resolve(pageTypeMeta.content.toLowerCase());\n            } else {\n                reject('unknown');\n            }\n        }\n        if (counter >= 10) {\n            clearInterval(interval);\n            reject('unknown');\n        }\n    }, 100);\n}).then((response) => (response), () => ('unknown'));\n"},15211:{code:"// DYO.Q\nconst positive = () => 'True';\nconst negative = (error) => {\n    console.warn(error);\n    return 'False'\n};\nconst hasLaptopsOrDisplays = () => new Promise((resolve, reject) => {\n    console.debug('hasLaptopsOrDisplays: Running');\n    const interval = setInterval(() => {\n        if (window.dataLayer && window.DY && window.DY.ServerUtil && window.DY.ServerUtil.getProductsData && typeof window.DY.ServerUtil.getProductsData === 'function') {\n            for (let i = 0; i < window.dataLayer.length; i += 1) {\n                const index = dataLayer.findIndex((node) => node.event === 'e_pageView');\n                if (index !== -1) {\n                    clearInterval(interval);\n                    const pageViewNode = dataLayer[index];\n                    if (pageViewNode.ecommerce && pageViewNode.ecommerce.detail && pageViewNode.ecommerce.detail.products && pageViewNode.ecommerce.detail.products.length > 0) {\n                        const allSkus = [];\n                        const dataLayerProducts = pageViewNode.ecommerce.detail.products || [];\n                        for (let i = 0; i < dataLayerProducts.length; i += 1) {\n                            if (dataLayerProducts[i].quantity && dataLayerProducts[i].quantity > 1) {\n                                reject('hasLaptopsOrDisplays: Multiple quantities of a product');\n                                return;\n                            }\n                            allSkus.push(dataLayerProducts[i].id);\n                        }\n                        if (allSkus.length >= 3) {\n                            reject('hasLaptopsOrDisplays: Too many products');\n                            return;\n                        }\n                        DY.ServerUtil.getProductsData(allSkus, null, null, true, (error, response) => {\n                            if (error) reject('hasLaptopsOrDisplays: Error');\n                            else if (Object.keys(response).length === 0) reject('hasLaptopsOrDisplays: Not enough data');\n                            else {\n                                const allCategories = [];\n                                Object.values(response).forEach((data) => {\n                                    const { productData } = data;\n                                    if (productData && productData.categories) allCategories.push(productData.categories);\n                                });\n                                if (allSkus.length === 1) {\n                                    if (allCategories.includes('Laptops') || allCategories.includes('Workstations') || allCategories.includes('Desktops') || allCategories.includes('Printers')) resolve(true);\n                                    else reject('hasLaptopsOrDisplays: No relevant categories found');\n                                }\n                                else if (allCategories.includes('Laptops') && allCategories.includes('Monitors')) resolve(true);\n                                else if (allCategories.includes('Desktops') && allCategories.includes('Monitors')) resolve(true);\n                                else if (allCategories.includes('Workstations') && allCategories.includes('Monitors')) resolve(true);\n                                else if (allCategories.includes('Printers') && allCategories.includes('Monitors')) resolve(true);\n                                else reject('hasLaptopsOrDisplays: No relevant categories found');\n                            }\n                        });\n                    }\n                    break;\n                }\n            }\n        }\n    });\n    setTimeout(() => {\n        reject('hasLaptopsOrDisplays: Timed out');\n        clearInterval(interval);\n    }, 3000);\n});\nhasLaptopsOrDisplays().then(positive, negative).catch(negative);"},15506:{code:"DYO.Q.Promise(function (resolve) {\n  var interval = setInterval(function () {\n    try {\n      if (!window.dataLayer || !Array.isArray(window.dataLayer)) {\n        return;\n      }\n\n      for (var i = window.dataLayer.length - 1; i >= 0; i--) {\n        var dl = window.dataLayer[i];\n\n        if (dl.event === 'e_pageView' && typeof dl.pageNameL5 === 'string') {\n          var pageType = dl.pageNameL5.toLowerCase();\n\n          var isPDP = pageType === 'pdp';\n          var isDisqualifying = ['home', 'cart', 'checkout', 'landing', 'plp'].indexOf(pageType) !== -1;\n\n          // ❌ Permanently disqualify session when hitting a non-PDP\n          if (isDisqualifying) {\n            sessionStorage.setItem('dy_pdp_only_invalid', 'true');\n          }\n\n          // ✅ Lock initial page type (only once)\n          if (!sessionStorage.getItem('dy_pdp_only_started')) {\n            sessionStorage.setItem('dy_pdp_only_started', isPDP ? 'pdp' : 'other');\n          }\n\n          var startedOnPDP = sessionStorage.getItem('dy_pdp_only_started') === 'pdp';\n          var notInvalidated = sessionStorage.getItem('dy_pdp_only_invalid') !== 'true';\n\n          clearInterval(interval);\n          resolve(isPDP && startedOnPDP && notInvalidated);\n          return;\n        }\n      }\n    } catch (e) {\n      clearInterval(interval);\n      resolve(false);\n    }\n  }, 100);\n\n  setTimeout(function () {\n    clearInterval(interval);\n    resolve(false);\n  }, 5000);\n});"},15521:{code:'(function() {\n    try {\n        var dl = window.dataLayer || [];\n        var ev = dl.find(function(i) {\n            return i.event === "e_pageView" && i.ecommerce && i.ecommerce.detail && i.ecommerce.detail.products;\n        });\n\n        if (!ev) return "WAITING_FOR_DATA";\n\n        var prods = ev.ecommerce.detail.products;\n        var ids = [];\n        prods.forEach(function(p) {\n            if (ids.indexOf(p.id) === -1) { ids.push(p.id); }\n        });\n\n        // Safety: Only trigger for single-item carts\n        if (ids.length > 1) return "BLOCK_MULTIPLE_ITEMS";\n\n        if (ids.length === 1) {\n            var brand = (prods[0].brand || "no-brand").toLowerCase();\n            var category = prods[0].category || "no-category";\n            // Returns a string like: "omen | M7/laptops/HP Home Laptop PCs..."\n            return brand + " | " + category;\n        }\n\n        return "BLOCK_NO_DATA";\n    } catch (e) {\n        return "BLOCK_ERROR";\n    }\n})();'}},e.debug=e.debug||!1,e.expSesMs=e.expSesMs||18e5,e.cookieManagedExperiments=[],e.smartVariableExperimentsMapV1={},e.smartVariableExperimentsV1={},e.rcom=e.rcom||a,e.translations=e.translations||o,e.sectionConfig=e.sectionConfigs||{url_normalization_method:"href",data_sources:[{name:"ds9881447_affinity",display:"Affinity CRM for 9881447",integrationType:"crm"}],platform:"web",context_rules:[],primary_identifier:"ihe",secondary_identifiers:[]},e.sectionFeatures=e.sectionFeatures||{AB_TEST_HISTORY:{enabled:!0},ACTIVE_CONSENT:{enabled:!0},AFFINITY_BACKEND_SUPPORT:{enabled:!0},AFFINITY_ML:{enabled:!0},AFFINITY_ML_BACKEND_SUPPORT:{enabled:!0},ALGORITHM_STUDIO:{enabled:!0},ALL_OPTIONS_IN_RECOMMENDATION_RULE
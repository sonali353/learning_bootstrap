define(['jquery','Magento_PageBuilder/js/events','Magento_Ui/js/modal/modal'],function($,events,modal){'use strict';return function(config,element){$(document).on('click','a.link-item',function(e){e.preventDefault();e.stopImmediatePropagation();var $btn=$(this);var $slickCanvas=$btn.closest('.hp-custom-slider');var $existingModal=$btn.data('detachedModal');if(!$existingModal){var $originalContent=$btn.closest('.hp-pagebuilder-extend.pagebuilder-hpols-banner').find('.disclaimer-terms');if($originalContent.length>0){var $clonedContent=$originalContent.clone().appendTo('body');var options={type:'popup',modalClass:'vertical-center-modal',responsive:true,opened:function(){if($slickCanvas.hasClass('slick-initialized')){let pauseButton=$slickCanvas.find('.pause-button');pauseButton.is(':visible')&&pauseButton.trigger('click');}},closed:function(){if($slickCanvas.hasClass('slick-initialized')){setTimeout(function(){let playButton=$slickCanvas.find('.play-button');playButton.is(':visible')&&playButton.trigger('click');$slickCanvas.slick('setPosition');},200);}},buttons:[]};modal(options,$clonedContent);$clonedContent.modal('openModal');$btn.data('detachedModal',$clonedContent);}else{console.warn('Modal content [.disclaimer-terms] not found in this banner.');}}else{$existingModal.modal('openModal');}});}});